<%- include('../partials/header', { title: title }) %>

<div class="container py-5">
  <!-- Page Header -->
  <div class="d-flex flex-wrap justify-content-between align-items-center mb-5 gap-3">
    <div>
      <h1 class="fw-bold mb-1">Employer Dashboard</h1>
      <p class="text-muted mb-0">Welcome back, <span class="text-white"><%= currentUser.name %></span></p>
    </div>
    <a href="/employer/jobs/create" class="btn btn-primary">
      <i class="bi bi-plus-circle me-2"></i>Post New Job
    </a>
  </div>

  <!-- Stats -->
  <div class="row g-3 mb-5">
    <div class="col-6 col-md-3">
      <div class="stat-card card text-center p-3">
        <div class="stat-icon text-primary"><i class="bi bi-briefcase-fill"></i></div>
        <div class="stat-num"><%= stats.total_jobs || 0 %></div>
        <div class="stat-lbl">Total Jobs</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card card text-center p-3">
        <div class="stat-icon text-success"><i class="bi bi-check-circle-fill"></i></div>
        <div class="stat-num"><%= stats.active_jobs || 0 %></div>
        <div class="stat-lbl">Active</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card card text-center p-3">
        <div class="stat-icon text-warning"><i class="bi bi-people-fill"></i></div>
        <div class="stat-num"><%= stats.total_applications || 0 %></div>
        <div class="stat-lbl">Applications</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card card text-center p-3">
        <div class="stat-icon text-secondary"><i class="bi bi-archive-fill"></i></div>
        <div class="stat-num"><%= stats.closed_jobs || 0 %></div>
        <div class="stat-lbl">Closed</div>
      </div>
    </div>
  </div>

  <!-- Jobs Table -->
  <div class="card detail-card">
    <div class="card-header d-flex justify-content-between align-items-center py-3 px-4">
      <h5 class="mb-0 fw-bold"><i class="bi bi-briefcase me-2"></i>My Job Postings</h5>
      <a href="/employer/jobs/create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus me-1"></i>Post Job
      </a>
    </div>

    <% if (jobs.length === 0) { %>
      <div class="card-body text-center py-5">
        <i class="bi bi-briefcase display-1 text-muted opacity-25"></i>
        <h5 class="mt-3 text-muted">No jobs posted yet</h5>
        <p class="text-muted small">Post your first job and start finding talent.</p>
        <a href="/employer/jobs/create" class="btn btn-primary mt-2">Post a Job</a>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0">
          <thead>
            <tr>
              <th class="px-4">Job Title</th>
              <th>Type</th>
              <th>Status</th>
              <th class="text-center">Applications</th>
              <th>Posted</th>
              <th class="text-end px-4">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% jobs.forEach(job => { %>
            <tr>
              <td class="px-4">
                <div class="fw-semibold"><%= job.title %></div>
                <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i><%= job.location %></div>
              </td>
              <td><span class="badge type-badge type-<%= job.type %>"><%= job.type %></span></td>
              <td>
                <span class="badge bg-<%= job.status === 'active' ? 'success' : job.status === 'draft' ? 'warning text-dark' : 'secondary' %>">
                  <%= job.status %>
                </span>
              </td>
              <td class="text-center">
                <a href="/employer/jobs/<%= job.id %>/applicants" class="btn btn-sm btn-outline-info">
                  <i class="bi bi-people me-1"></i><%= job.app_count %>
                </a>
              </td>
              <td class="text-muted small"><%= new Date(job.created_at).toLocaleDateString() %></td>
              <td class="text-end px-4">
                <div class="btn-group btn-group-sm">
                  <a href="/jobs/<%= job.id %>" class="btn btn-outline-secondary" title="View">
                    <i class="bi bi-eye"></i>
                  </a>
                  <a href="/employer/jobs/<%= job.id %>/edit" class="btn btn-outline-primary" title="Edit">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <form action="/employer/jobs/<%= job.id %>?_method=DELETE" method="POST"
                    onsubmit="return confirm('Delete this job? All applications will also be deleted.')">
                    <button type="submit" class="btn btn-outline-danger" title="Delete">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
