<%- include('../partials/header', { title: title }) %>

<div class="container py-5">
  <div class="row g-4">
    <!-- Main Content -->
    <div class="col-lg-8">
      <!-- Job Header Card -->
      <div class="card detail-card mb-4">
        <div class="card-body p-4 p-lg-5">
          <div class="d-flex gap-3 align-items-start mb-4">
            <div class="company-avatar company-avatar-lg"><%= job.company.charAt(0).toUpperCase() %></div>
            <div class="flex-grow-1">
              <div class="d-flex flex-wrap gap-2 mb-2">
                <span class="badge type-badge type-<%= job.type %>"><%= job.type %></span>
                <span class="badge bg-<%= job.status === 'active' ? 'success' : 'secondary' %>"><%= job.status %></span>
              </div>
              <h1 class="h2 fw-bold mb-1"><%= job.title %></h1>
              <p class="text-muted mb-0 fs-5"><%= job.company %></p>
            </div>
          </div>

          <!-- Meta Info -->
          <div class="row g-3 mb-4">
            <div class="col-sm-6 col-md-3">
              <div class="meta-info-item">
                <i class="bi bi-geo-alt-fill text-primary"></i>
                <div>
                  <div class="meta-label">Location</div>
                  <div class="meta-value"><%= job.location %></div>
                </div>
              </div>
            </div>
            <div class="col-sm-6 col-md-3">
              <div class="meta-info-item">
                <i class="bi bi-briefcase-fill text-primary"></i>
                <div>
                  <div class="meta-label">Job Type</div>
                  <div class="meta-value text-capitalize"><%= job.type %></div>
                </div>
              </div>
            </div>
            <% if (job.salary_min || job.salary_max) { %>
            <div class="col-sm-6 col-md-3">
              <div class="meta-info-item">
                <i class="bi bi-cash-stack text-success"></i>
                <div>
                  <div class="meta-label">Salary</div>
                  <div class="meta-value text-success">
                    <% if (job.salary_min && job.salary_max) { %>
                      $<%= job.salary_min.toLocaleString() %> – $<%= job.salary_max.toLocaleString() %>
                    <% } else if (job.salary_min) { %>
                      From $<%= job.salary_min.toLocaleString() %>
                    <% } else { %>
                      Up to $<%= job.salary_max.toLocaleString() %>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
            <% } %>
            <div class="col-sm-6 col-md-3">
              <div class="meta-info-item">
                <i class="bi bi-bar-chart-fill text-warning"></i>
                <div>
                  <div class="meta-label">Experience</div>
                  <div class="meta-value text-capitalize"><%= job.experience_level || 'Any' %></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Apply Button (mobile) -->
          <div class="d-lg-none">
            <% if (!currentUser) { %>
              <a href="/auth/login" class="btn btn-primary w-100 py-2 mb-2">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign in to Apply
              </a>
            <% } else if (currentUser.role === 'seeker') { %>
              <% if (job.status !== 'active') { %>
                <button class="btn btn-secondary w-100 py-2 mb-2" disabled>Job Closed</button>
              <% } else if (alreadyApplied) { %>
                <button class="btn btn-success w-100 py-2 mb-2" disabled>
                  <i class="bi bi-check-circle me-2"></i>Applied
                </button>
              <% } else { %>
                <button class="btn btn-primary w-100 py-2 mb-2" data-bs-toggle="modal" data-bs-target="#applyModal">
                  <i class="bi bi-send me-2"></i>Apply Now
                </button>
              <% } %>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Description -->
      <div class="card detail-card mb-4">
        <div class="card-body p-4 p-lg-5">
          <h4 class="fw-bold mb-4"><i class="bi bi-file-text me-2 text-primary"></i>Job Description</h4>
          <div class="job-content"><%= job.description.replace(/\n/g, '<br/>') %></div>
        </div>
      </div>

      <% if (job.requirements) { %>
      <div class="card detail-card mb-4">
        <div class="card-body p-4 p-lg-5">
          <h4 class="fw-bold mb-4"><i class="bi bi-list-check me-2 text-primary"></i>Requirements</h4>
          <div class="job-content"><%= job.requirements.replace(/\n/g, '<br/>') %></div>
        </div>
      </div>
      <% } %>

      <% if (job.benefits) { %>
      <div class="card detail-card mb-4">
        <div class="card-body p-4 p-lg-5">
          <h4 class="fw-bold mb-4"><i class="bi bi-gift me-2 text-success"></i>Benefits &amp; Perks</h4>
          <div class="job-content"><%= job.benefits.replace(/\n/g, '<br/>') %></div>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
      <!-- Apply Card -->
      <div class="card detail-card mb-4 sticky-top" style="top: 80px;">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-3">Ready to Apply?</h5>

          <% if (!currentUser) { %>
            <p class="text-muted small mb-3">Create a free account or sign in to apply instantly.</p>
            <a href="/auth/login" class="btn btn-primary w-100 mb-2">
              <i class="bi bi-box-arrow-in-right me-2"></i>Sign In to Apply
            </a>
            <a href="/auth/register" class="btn btn-outline-primary w-100">Create Free Account</a>

          <% } else if (currentUser.role === 'seeker') { %>
            <% if (job.status !== 'active') { %>
              <div class="alert alert-warning mb-0 small">This job is no longer accepting applications.</div>
            <% } else if (alreadyApplied) { %>
              <div class="alert alert-success mb-3 d-flex align-items-center gap-2">
                <i class="bi bi-check-circle-fill"></i>
                <span>You've already applied!</span>
              </div>
              <a href="/seeker/applications" class="btn btn-outline-success w-100">View My Applications</a>
            <% } else { %>
              <button class="btn btn-primary w-100 py-2 fw-semibold" data-bs-toggle="modal" data-bs-target="#applyModal">
                <i class="bi bi-send me-2"></i>Apply Now
              </button>
            <% } %>

          <% } else if (currentUser.role === 'employer') { %>
            <p class="text-muted small mb-0">You're logged in as an employer.</p>

          <% } else if (currentUser.role === 'admin') { %>
            <a href="/admin/jobs" class="btn btn-outline-warning w-100">Manage This Job</a>
          <% } %>

          <hr class="my-4" />
          <div class="d-flex flex-column gap-2 small text-muted">
            <div><i class="bi bi-calendar3 me-2"></i>Posted <%= new Date(job.created_at).toLocaleDateString('en-US', {year:'numeric', month:'long', day:'numeric'}) %></div>
            <div><i class="bi bi-building me-2"></i><%= job.company %></div>
            <div><i class="bi bi-geo-alt me-2"></i><%= job.location %></div>
          </div>
        </div>
      </div>

      <!-- Company Card -->
      <div class="card detail-card mb-4">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-3">About the Company</h5>
          <div class="d-flex align-items-center gap-3 mb-3">
            <div class="company-avatar"><%= job.company.charAt(0).toUpperCase() %></div>
            <div>
              <div class="fw-semibold"><%= job.company %></div>
              <% if (job.company_name) { %><div class="text-muted small"><%= job.company_name %></div><% } %>
            </div>
          </div>
          <% if (job.employer_bio) { %><p class="text-muted small"><%= job.employer_bio %></p><% } %>
          <% if (job.company_website) { %>
            <a href="<%= job.company_website %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary btn-sm w-100">
              <i class="bi bi-globe me-1"></i>Company Website
            </a>
          <% } %>
        </div>
      </div>

      <!-- Similar Jobs -->
      <% if (similar.length > 0) { %>
      <div class="card detail-card">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-3">Similar Jobs</h5>
          <div class="d-flex flex-column gap-2">
            <% similar.forEach(s => { %>
              <a href="/jobs/<%= s.id %>" class="similar-job-item text-decoration-none">
                <div class="fw-medium text-white small"><%= s.title %></div>
                <div class="text-muted small"><%= s.company %> &bull; <%= s.location %></div>
                <span class="badge type-badge type-<%= s.type %> mt-1"><%= s.type %></span>
              </a>
            <% }) %>
          </div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Apply Modal -->
<% if (currentUser && currentUser.role === 'seeker' && job.status === 'active' && !alreadyApplied) { %>
<div class="modal fade" id="applyModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold">Apply for <%= job.title %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/seeker/apply/<%= job.id %>" method="POST">
        <div class="modal-body">
          <div class="alert alert-info small d-flex gap-2 align-items-start">
            <i class="bi bi-info-circle-fill mt-1"></i>
            <span>Applying as <strong><%= currentUser.name %></strong> (<%= currentUser.email %>)</span>
          </div>
          <div class="mb-3">
            <label class="form-label fw-medium">Cover Letter <span class="text-muted fw-normal">(optional)</span></label>
            <textarea class="form-control" name="cover_letter" rows="6"
              placeholder="Introduce yourself and explain why you're a great fit for this role..."></textarea>
            <div class="form-text">A personalized cover letter significantly increases your chances.</div>
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary fw-semibold">
            <i class="bi bi-send me-2"></i>Submit Application
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>

<%- include('../partials/footer') %>
