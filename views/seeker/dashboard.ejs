<%- include('../partials/header', { title: title }) %>

<div class="container py-5">
  <div class="d-flex flex-wrap justify-content-between align-items-center mb-5 gap-3">
    <div>
      <h1 class="fw-bold mb-1">My Dashboard</h1>
      <p class="text-muted mb-0">Welcome back, <span class="text-white"><%= currentUser.name %></span></p>
    </div>
    <a href="/" class="btn btn-primary">
      <i class="bi bi-search me-2"></i>Browse Jobs
    </a>
  </div>

  <!-- Stats -->
  <div class="row g-3 mb-5">
    <div class="col-6 col-md-3">
      <div class="stat-card card text-center p-3">
        <div class="stat-icon text-primary"><i class="bi bi-file-text-fill"></i></div>
        <div class="stat-num"><%= stats.total || 0 %></div>
        <div class="stat-lbl">Total Applied</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card card text-center p-3">
        <div class="stat-icon text-warning"><i class="bi bi-hourglass-split"></i></div>
        <div class="stat-num"><%= stats.pending || 0 %></div>
        <div class="stat-lbl">Pending</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card card text-center p-3">
        <div class="stat-icon text-info"><i class="bi bi-star-fill"></i></div>
        <div class="stat-num"><%= stats.shortlisted || 0 %></div>
        <div class="stat-lbl">Shortlisted</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card card text-center p-3">
        <div class="stat-icon text-success"><i class="bi bi-trophy-fill"></i></div>
        <div class="stat-num"><%= stats.hired || 0 %></div>
        <div class="stat-lbl">Hired</div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- Recent Applications -->
    <div class="col-lg-7">
      <div class="card detail-card h-100">
        <div class="card-header d-flex justify-content-between align-items-center py-3 px-4">
          <h5 class="mb-0 fw-bold"><i class="bi bi-file-text me-2"></i>Recent Applications</h5>
          <a href="/seeker/applications" class="btn btn-sm btn-outline-primary">View All</a>
        </div>
        <% if (applications.length === 0) { %>
          <div class="card-body text-center py-5">
            <i class="bi bi-file-earmark-x display-1 text-muted opacity-25"></i>
            <h5 class="mt-3 text-muted">No applications yet</h5>
            <p class="text-muted small">Start applying for jobs to see them here.</p>
            <a href="/" class="btn btn-primary btn-sm">Find Jobs</a>
          </div>
        <% } else { %>
          <div class="list-group list-group-flush">
            <% applications.forEach(app => { %>
              <div class="list-group-item list-group-item-action py-3 px-4">
                <div class="d-flex justify-content-between align-items-start">
                  <div class="flex-grow-1">
                    <a href="/jobs/<%= app.job_id %>" class="fw-semibold text-white text-decoration-none"><%= app.title %></a>
                    <div class="text-muted small mt-1">
                      <span><i class="bi bi-building me-1"></i><%= app.company %></span>
                      <span class="mx-2">&bull;</span>
                      <span><i class="bi bi-geo-alt me-1"></i><%= app.location %></span>
                    </div>
                  </div>
                  <div class="text-end ms-3">
                    <span class="badge status-badge status-<%= app.status %>"><%= app.status %></span>
                    <div class="text-muted small mt-1"><%= new Date(app.created_at).toLocaleDateString() %></div>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Recent Job Listings -->
    <div class="col-lg-5">
      <div class="card detail-card h-100">
        <div class="card-header d-flex justify-content-between align-items-center py-3 px-4">
          <h5 class="mb-0 fw-bold"><i class="bi bi-lightning me-2"></i>Fresh Listings</h5>
          <a href="/" class="btn btn-sm btn-outline-primary">Browse All</a>
        </div>
        <div class="list-group list-group-flush">
          <% recentJobs.forEach(job => { %>
            <a href="/jobs/<%= job.id %>" class="list-group-item list-group-item-action py-3 px-4 text-decoration-none">
              <div class="d-flex gap-3 align-items-center">
                <div class="company-avatar-sm"><%= job.company.charAt(0).toUpperCase() %></div>
                <div class="flex-grow-1 overflow-hidden">
                  <div class="fw-semibold text-white text-truncate"><%= job.title %></div>
                  <div class="text-muted small text-truncate"><%= job.company %> &bull; <%= job.location %></div>
                </div>
                <span class="badge type-badge type-<%= job.type %> flex-shrink-0"><%= job.type %></span>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
