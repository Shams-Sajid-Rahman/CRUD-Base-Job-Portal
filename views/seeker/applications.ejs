<%- include('../partials/header', { title: title }) %>

<div class="container py-5">
  <div class="d-flex flex-wrap justify-content-between align-items-center mb-5 gap-3">
    <div>
      <h1 class="fw-bold mb-1">My Applications</h1>
      <p class="text-muted mb-0"><%= applications.length %> total application<%= applications.length !== 1 ? 's' : '' %></p>
    </div>
    <a href="/" class="btn btn-primary">
      <i class="bi bi-search me-2"></i>Find More Jobs
    </a>
  </div>

  <% if (applications.length === 0) { %>
    <div class="card detail-card text-center py-5">
      <i class="bi bi-file-earmark-x display-1 text-muted opacity-25"></i>
      <h5 class="mt-3 text-muted">No applications yet</h5>
      <p class="text-muted small">Start applying to jobs to track your progress here.</p>
      <a href="/" class="btn btn-primary mt-2">Browse Jobs</a>
    </div>
  <% } else { %>
    <div class="d-flex flex-column gap-3">
      <% applications.forEach(app => { %>
        <div class="card detail-card application-item">
          <div class="card-body p-4">
            <div class="row g-3 align-items-center">
              <div class="col-md-5">
                <div class="d-flex align-items-center gap-3">
                  <div class="company-avatar"><%= app.company.charAt(0).toUpperCase() %></div>
                  <div>
                    <a href="/jobs/<%= app.job_id %>" class="fw-semibold fs-6 text-white text-decoration-none"><%= app.title %></a>
                    <div class="text-muted small mt-1">
                      <i class="bi bi-building me-1"></i><%= app.company %>
                    </div>
                    <div class="text-muted small">
                      <i class="bi bi-geo-alt me-1"></i><%= app.location %>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col-md-2">
                <span class="badge type-badge type-<%= app.type %>"><%= app.type %></span>
                <% if (app.salary_min || app.salary_max) { %>
                  <div class="text-success small mt-1">
                    <% if (app.salary_min && app.salary_max) { %>
                      $<%= (app.salary_min/1000).toFixed(0) %>k–$<%= (app.salary_max/1000).toFixed(0) %>k
                    <% } %>
                  </div>
                <% } %>
              </div>
              <div class="col-md-2 text-center">
                <span class="badge status-badge status-<%= app.status %> px-3 py-2"><%= app.status %></span>
              </div>
              <div class="col-md-2 text-muted small">
                <i class="bi bi-calendar3 me-1"></i>
                <%= new Date(app.created_at).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) %>
                <div class="mt-1">
                  <span class="badge bg-<%= app.job_status === 'active' ? 'success' : 'secondary' %> small">
                    Job: <%= app.job_status %>
                  </span>
                </div>
              </div>
              <div class="col-md-1 text-end">
                <% if (app.status === 'pending') { %>
                  <form action="/seeker/applications/<%= app.id %>?_method=DELETE" method="POST"
                    onsubmit="return confirm('Withdraw this application?')">
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Withdraw">
                      <i class="bi bi-x-circle"></i>
                    </button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Status legend -->
    <div class="card detail-card mt-4">
      <div class="card-body p-3">
        <div class="d-flex flex-wrap gap-3 align-items-center">
          <span class="text-muted small fw-medium">Status Guide:</span>
          <% ['pending','reviewed','shortlisted','rejected','hired'].forEach(s => { %>
            <span class="badge status-badge status-<%= s %>"><%= s %></span>
          <% }) %>
        </div>
      </div>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
