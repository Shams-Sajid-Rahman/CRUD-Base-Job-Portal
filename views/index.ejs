<%- include('./partials/header', { title: title }) %>

<!-- Hero Section -->
<section class="hero-section">
  <div class="container">
    <div class="row justify-content-center text-center">
      <div class="col-lg-8">
        <div class="badge badge-hero mb-3"><i class="bi bi-stars me-1"></i> #1 Job Portal Platform</div>
        <h1 class="display-4 fw-bold mb-3">Find Your <span class="text-gradient">Dream Career</span></h1>
        <p class="lead text-muted mb-5">Discover thousands of job opportunities from top companies. Your next big opportunity starts here.</p>

        <!-- Search Form -->
        <form action="/" method="GET" class="search-form">
          <div class="row g-2">
            <div class="col-md-5">
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control" name="q" placeholder="Job title or keyword" value="<%= q %>" />
              </div>
            </div>
            <div class="col-md-3">
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                <input type="text" class="form-control" name="location" placeholder="Location" value="<%= location %>" />
              </div>
            </div>
            <div class="col-md-2">
              <select class="form-select" name="type">
                <option value="">All Types</option>
                <option value="full-time" <%= type==='full-time'?'selected':'' %>>Full-time</option>
                <option value="part-time" <%= type==='part-time'?'selected':'' %>>Part-time</option>
                <option value="contract" <%= type==='contract'?'selected':'' %>>Contract</option>
                <option value="remote" <%= type==='remote'?'selected':'' %>>Remote</option>
                <option value="internship" <%= type==='internship'?'selected':'' %>>Internship</option>
              </select>
            </div>
            <div class="col-md-2">
              <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i> Search</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- Stats Bar -->
<section class="stats-bar py-4">
  <div class="container">
    <div class="row g-3 text-center">
      <div class="col-4">
        <div class="stat-item">
          <div class="stat-number"><%= stats.active_jobs || 0 %>+</div>
          <div class="stat-label">Active Jobs</div>
        </div>
      </div>
      <div class="col-4">
        <div class="stat-item">
          <div class="stat-number"><%= stats.employers || 0 %>+</div>
          <div class="stat-label">Companies</div>
        </div>
      </div>
      <div class="col-4">
        <div class="stat-item">
          <div class="stat-number"><%= stats.seekers || 0 %>+</div>
          <div class="stat-label">Job Seekers</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Job Listings -->
<section class="py-5">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="fw-bold mb-0">
          <% if (q || location || type) { %>
            Search Results
          <% } else { %>
            Latest Jobs
          <% } %>
        </h2>
        <p class="text-muted small mb-0"><%= total %> job<%= total !== 1 ? 's' : '' %> found</p>
      </div>
      <% if (q || location || type) { %>
        <a href="/" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-circle me-1"></i>Clear Filters</a>
      <% } %>
    </div>

    <% if (jobs.length === 0) { %>
      <div class="empty-state text-center py-5">
        <i class="bi bi-briefcase display-1 text-muted opacity-25"></i>
        <h4 class="mt-3 text-muted">No jobs found</h4>
        <p class="text-muted">Try adjusting your search filters.</p>
        <a href="/" class="btn btn-primary mt-2">Clear Search</a>
      </div>
    <% } else { %>
      <div class="row g-3">
        <% jobs.forEach(job => { %>
          <div class="col-md-6 col-lg-4">
            <a href="/jobs/<%= job.id %>" class="text-decoration-none">
              <div class="job-card card h-100">
                <div class="card-body p-4">
                  <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="company-avatar"><%= job.company.charAt(0).toUpperCase() %></div>
                    <span class="badge type-badge type-<%= job.type %>"><%= job.type %></span>
                  </div>
                  <h5 class="card-title fw-semibold mb-1 text-white"><%= job.title %></h5>
                  <p class="text-muted small mb-3"><%= job.company %></p>
                  <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="meta-chip"><i class="bi bi-geo-alt"></i> <%= job.location %></span>
                    <% if (job.salary_min || job.salary_max) { %>
                      <span class="meta-chip text-success">
                        <i class="bi bi-currency-dollar"></i>
                        <% if (job.salary_min && job.salary_max) { %>
                          <%= (job.salary_min/1000).toFixed(0) %>k – <%= (job.salary_max/1000).toFixed(0) %>k
                        <% } else if (job.salary_min) { %>
                          From $<%= job.salary_min.toLocaleString() %>
                        <% } %>
                      </span>
                    <% } %>
                  </div>
                  <p class="text-muted small job-excerpt mb-0"><%= job.description.substring(0, 100) %>...</p>
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center">
                  <small class="text-muted">
                    <i class="bi bi-clock me-1"></i>
                    <%= new Date(job.created_at).toLocaleDateString('en-US', {month:'short', day:'numeric'}) %>
                  </small>
                  <span class="text-primary small fw-medium">View Details <i class="bi bi-arrow-right"></i></span>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>

      <!-- Pagination -->
      <% if (pages > 1) { %>
        <nav class="mt-5 d-flex justify-content-center">
          <ul class="pagination">
            <% if (page > 1) { %>
              <li class="page-item">
                <a class="page-link" href="/?page=<%= page-1 %>&q=<%= q %>&location=<%= location %>&type=<%= type %>">
                  <i class="bi bi-chevron-left"></i>
                </a>
              </li>
            <% } %>
            <% for (let i = 1; i <= pages; i++) { %>
              <li class="page-item <%= i === page ? 'active' : '' %>">
                <a class="page-link" href="/?page=<%= i %>&q=<%= q %>&location=<%= location %>&type=<%= type %>"><%= i %></a>
              </li>
            <% } %>
            <% if (page < pages) { %>
              <li class="page-item">
                <a class="page-link" href="/?page=<%= page+1 %>&q=<%= q %>&location=<%= location %>&type=<%= type %>">
                  <i class="bi bi-chevron-right"></i>
                </a>
              </li>
            <% } %>
          </ul>
        </nav>
      <% } %>
    <% } %>
  </div>
</section>

<!-- CTA Section -->
<% if (!currentUser) { %>
<section class="cta-section py-5">
  <div class="container">
    <div class="row g-4">
      <div class="col-md-6">
        <div class="cta-card cta-seeker p-4 rounded-3 h-100">
          <i class="bi bi-person-check display-4 mb-3 d-block"></i>
          <h4 class="fw-bold">Looking for a Job?</h4>
          <p class="text-muted">Create your free account and apply to hundreds of jobs with one click.</p>
          <a href="/auth/register" class="btn btn-primary">Register as Job Seeker</a>
        </div>
      </div>
      <div class="col-md-6">
        <div class="cta-card cta-employer p-4 rounded-3 h-100">
          <i class="bi bi-building display-4 mb-3 d-block"></i>
          <h4 class="fw-bold">Hiring Talent?</h4>
          <p class="text-muted">Post your jobs and reach thousands of qualified candidates instantly.</p>
          <a href="/auth/register" class="btn btn-outline-primary">Register as Employer</a>
        </div>
      </div>
    </div>
  </div>
</section>
<% } %>

<%- include('./partials/footer') %>
