<%- include('../partials/header', { title: title }) %>

<div class="container py-5">
  <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <div>
      <h1 class="fw-bold mb-1">Manage Jobs</h1>
      <p class="text-muted mb-0"><%= total %> total job<%= total !== 1 ? 's' : '' %></p>
    </div>
    <a href="/admin/dashboard" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i>Dashboard
    </a>
  </div>

  <!-- Filters -->
  <form action="/admin/jobs" method="GET" class="card detail-card p-3 mb-4">
    <div class="row g-2 align-items-end">
      <div class="col-md-5">
        <input type="text" class="form-control" name="q" placeholder="Search by title or company..." value="<%= q %>" />
      </div>
      <div class="col-md-3">
        <select class="form-select" name="status">
          <option value="">All Statuses</option>
          <option value="active" <%= status==='active'?'selected':'' %>>Active</option>
          <option value="draft" <%= status==='draft'?'selected':'' %>>Draft</option>
          <option value="closed" <%= status==='closed'?'selected':'' %>>Closed</option>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i>Filter</button>
      </div>
      <div class="col-md-2">
        <a href="/admin/jobs" class="btn btn-outline-secondary w-100">Clear</a>
      </div>
    </div>
  </form>

  <div class="card detail-card">
    <div class="table-responsive">
      <table class="table table-dark table-hover align-middle mb-0">
        <thead>
          <tr>
            <th class="px-4">Job</th>
            <th>Employer</th>
            <th>Type</th>
            <th>Status</th>
            <th class="text-center">Apps</th>
            <th>Posted</th>
            <th class="text-end px-4">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (jobs.length === 0) { %>
            <tr><td colspan="7" class="text-center py-4 text-muted">No jobs found.</td></tr>
          <% } %>
          <% jobs.forEach(job => { %>
          <tr>
            <td class="px-4">
              <a href="/jobs/<%= job.id %>" class="fw-semibold text-white text-decoration-none"><%= job.title %></a>
              <div class="text-muted small"><i class="bi bi-building me-1"></i><%= job.company %> &bull; <i class="bi bi-geo-alt me-1"></i><%= job.location %></div>
            </td>
            <td class="text-muted small"><%= job.employer_name %></td>
            <td><span class="badge type-badge type-<%= job.type %>"><%= job.type %></span></td>
            <td>
              <span class="badge bg-<%= job.status === 'active' ? 'success' : job.status === 'draft' ? 'warning text-dark' : 'secondary' %>">
                <%= job.status %>
              </span>
            </td>
            <td class="text-center">
              <span class="badge bg-secondary"><%= job.app_count %></span>
            </td>
            <td class="text-muted small"><%= new Date(job.created_at).toLocaleDateString() %></td>
            <td class="text-end px-4">
              <div class="d-flex gap-1 justify-content-end">
                <!-- Change status -->
                <form action="/admin/jobs/<%= job.id %>/status?_method=PUT" method="POST" class="d-flex gap-1">
                  <select class="form-select form-select-sm" name="status" style="width:110px;">
                    <% ['active','draft','closed'].forEach(s => { %>
                      <option value="<%= s %>" <%= job.status === s ? 'selected' : '' %>><%= s %></option>
                    <% }) %>
                  </select>
                  <button type="submit" class="btn btn-sm btn-outline-warning" title="Update Status">
                    <i class="bi bi-arrow-repeat"></i>
                  </button>
                </form>
                <!-- Delete -->
                <form action="/admin/jobs/<%= job.id %>?_method=DELETE" method="POST"
                  onsubmit="return confirm('Delete this job? All applications will be removed.')">
                  <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <% if (pages > 1) { %>
    <nav class="mt-4 d-flex justify-content-center">
      <ul class="pagination">
        <% if (page > 1) { %>
          <li class="page-item"><a class="page-link" href="/admin/jobs?page=<%= page-1 %>&q=<%= q %>&status=<%= status %>"><i class="bi bi-chevron-left"></i></a></li>
        <% } %>
        <% for (let i = 1; i <= pages; i++) { %>
          <li class="page-item <%= i===page?'active':'' %>">
            <a class="page-link" href="/admin/jobs?page=<%= i %>&q=<%= q %>&status=<%= status %>"><%= i %></a>
          </li>
        <% } %>
        <% if (page < pages) { %>
          <li class="page-item"><a class="page-link" href="/admin/jobs?page=<%= page+1 %>&q=<%= q %>&status=<%= status %>"><i class="bi bi-chevron-right"></i></a></li>
        <% } %>
      </ul>
    </nav>
  <% } %>
</div>

<%- include('../partials/footer') %>
