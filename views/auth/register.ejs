<%- include('../partials/header', { title: title }) %>

<section class="auth-section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="auth-card card">
          <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
              <div class="auth-logo mb-3"><i class="bi bi-person-plus-fill"></i></div>
              <h2 class="fw-bold">Create Account</h2>
              <p class="text-muted small">Join JobPortal today — it's free</p>
            </div>

            <!-- Role Tabs -->
            <div class="role-tabs mb-4">
              <div class="btn-group w-100" role="group">
                <input type="radio" class="btn-check" name="roleTab" id="seekerTab" autocomplete="off" checked />
                <label class="btn btn-outline-primary" for="seekerTab" onclick="setRole('seeker')">
                  <i class="bi bi-person me-1"></i>Job Seeker
                </label>
                <input type="radio" class="btn-check" name="roleTab" id="employerTab" autocomplete="off" />
                <label class="btn btn-outline-primary" for="employerTab" onclick="setRole('employer')">
                  <i class="bi bi-building me-1"></i>Employer
                </label>
              </div>
            </div>

            <form action="/auth/register" method="POST" enctype="multipart/form-data" novalidate>
              <input type="hidden" name="role" id="roleInput" value="seeker" />

              <div class="mb-3">
                <label class="form-label fw-medium">Full Name</label>
                <div class="input-group">
                  <span class="input-group-text"><i class="bi bi-person"></i></span>
                  <input type="text" class="form-control" name="name" placeholder="John Doe" required autofocus />
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label fw-medium">Email Address</label>
                <div class="input-group">
                  <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                  <input type="email" class="form-control" name="email" placeholder="you@example.com" required />
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label fw-medium">Phone Number</label>
                <div class="input-group">
                  <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                  <input type="tel" class="form-control" name="phone_number" placeholder="+880 1234-567890" required />
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label fw-medium">Bio</label>
                <textarea class="form-control" name="bio" placeholder="Tell us about yourself..." rows="3"></textarea>
              </div>

              <!-- NID field -->
              <div class="mb-3">
                <label class="form-label fw-medium">
                  National ID (NID) Number
                  <span class="text-danger">*</span>
                </label>
                <div class="input-group">
                  <span class="input-group-text"><i class="bi bi-credit-card-2-front"></i></span>
                  <input type="text" class="form-control" name="nid_number" id="nidInput"
                    placeholder="Enter your 10 or 17-digit NID number"
                    pattern="^\d{10}(\d{7})?$"
                    maxlength="17"
                    required />
                </div>
                <div class="form-text text-muted"><i class="bi bi-info-circle me-1"></i>Must be a valid 10 or 17-digit NID number.</div>
              </div>

              <!-- NID Image Upload -->
              <div class="mb-3">
                <label class="form-label fw-medium">
                  NID Photo / Scan
                  <span class="text-danger">*</span>
                </label>
                <div class="nid-upload-area" id="nidUploadArea" onclick="document.getElementById('nidImageInput').click()">
                  <div id="nidUploadPlaceholder">
                    <i class="bi bi-cloud-arrow-up fs-2 text-muted"></i>
                    <p class="mb-1 fw-medium">Click to upload NID image</p>
                    <p class="text-muted small mb-0">JPG, PNG, WEBP or PDF &mdash; max 5MB</p>
                  </div>
                  <div id="nidPreviewWrap" style="display:none;">
                    <img id="nidPreviewImg" src="" alt="NID Preview" class="nid-preview-img" />
                    <p id="nidFileName" class="text-muted small mt-2 mb-0"></p>
                  </div>
                </div>
                <input type="file" class="d-none" name="nid_image" id="nidImageInput"
                  accept=".jpg,.jpeg,.png,.webp,.pdf" required
                  onchange="previewNID(this)" />
              </div>

              <!-- Company field (employer only) -->
              <div class="mb-3" id="companyField" style="display:none;">
                <label class="form-label fw-medium">Company Name</label>
                <div class="input-group">
                  <span class="input-group-text"><i class="bi bi-building"></i></span>
                  <input type="text" class="form-control" name="company_name" placeholder="Acme Corp" />
                </div>
              </div>

              <!-- Company Website field (employer only) -->
              <div class="mb-3" id="companyWebsiteField" style="display:none;">
                <label class="form-label fw-medium">Company Website</label>
                <div class="input-group">
                  <span class="input-group-text"><i class="bi bi-globe"></i></span>
                  <input type="url" class="form-control" name="company_website" placeholder="https://example.com" />
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label fw-medium">Password</label>
                <div class="input-group">
                  <span class="input-group-text"><i class="bi bi-lock"></i></span>
                  <input type="password" class="form-control" name="password" id="passwordInput" placeholder="Min. 6 characters" required />
                  <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('passwordInput', this)">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
              </div>

              <div class="mb-4">
                <label class="form-label fw-medium">Confirm Password</label>
                <div class="input-group">
                  <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                  <input type="password" class="form-control" name="confirm_password" placeholder="Repeat password" required />
                </div>
              </div>

              <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                <i class="bi bi-person-check me-2"></i>Create Account
              </button>
            </form>

            <hr class="my-4" />
            <p class="text-center text-muted small mb-0">
              Already have an account?
              <a href="/auth/login" class="text-primary fw-medium">Sign in</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.nid-upload-area {
  border: 2px dashed #dee2e6;
  border-radius: 10px;
  padding: 24px;
  text-align: center;
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
}
.nid-upload-area:hover {
  border-color: #0d6efd;
  background: rgba(13,110,253,0.04);
}
.nid-preview-img {
  max-height: 140px;
  max-width: 100%;
  border-radius: 6px;
  border: 1px solid #dee2e6;
}
</style>

<script>
function previewNID(input) {
  const file = input.files[0];
  if (!file) return;
  document.getElementById('nidFileName').textContent = file.name;
  if (file.type.startsWith('image/')) {
    const reader = new FileReader();
    reader.onload = e => {
      document.getElementById('nidPreviewImg').src = e.target.result;
      document.getElementById('nidPreviewImg').style.display = 'block';
    };
    reader.readAsDataURL(file);
  } else {
    document.getElementById('nidPreviewImg').style.display = 'none';
  }
  document.getElementById('nidUploadPlaceholder').style.display = 'none';
  document.getElementById('nidPreviewWrap').style.display = 'block';
}

function setRole(role) {
  document.getElementById('roleInput').value = role;
  document.getElementById('companyField').style.display = role === 'employer' ? 'block' : 'none';
  document.getElementById('companyWebsiteField').style.display = role === 'employer' ? 'block' : 'none';
}
function togglePassword(inputId, btn) {
  const input = document.getElementById(inputId);
  const icon = btn.querySelector('i');
  if (input.type === 'password') {
    input.type = 'text';
    icon.className = 'bi bi-eye-slash';
  } else {
    input.type = 'password';
    icon.className = 'bi bi-eye';
  }
}
</script>

<%- include('../partials/footer') %>
